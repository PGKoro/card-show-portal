# Django
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (local docker-compose Postgres shown; point at your Supabase
# connection string in production)
DATABASE_URL=postgres://postgres:postgres@postgres:5432/card_show_portal

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# CORS - origins allowed to call this API
CORS_ALLOWED_ORIGINS=http://localhost:3000

# allauth
ACCOUNT_EMAIL_VERIFICATION=optional

# Google OAuth (create credentials in Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3000/auth/callback/google

# Microsoft OAuth (create an app registration in Azure/Entra ID)
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=common
MICROSOFT_OAUTH_CALLBACK_URL=http://localhost:3000/auth/callback/microsoft

# Supabase Storage (optional — media/venue-floor-plan uploads). Leave
# SUPABASE_URL blank to keep saving to local disk (fine locally; on a
# production host without persistent storage, uploads won't survive a
# redeploy/restart until this is filled in).
SUPABASE_URL=
SUPABASE_STORAGE_BUCKET=
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_REGION=us-east-1
